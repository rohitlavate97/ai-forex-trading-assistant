# ==============================================================================
# Environment Configuration Example
# Copy this file to .env and configure the variables for local development.
# Do NOT commit the .env file containing real secrets to version control.
# ==============================================================================

# Core Application Settings
ENV=development # development | production | testing
SECRET_KEY=replace-this-with-a-very-secure-random-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# FastAPI Backend Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
ALLOWED_HOSTS=http://localhost:3000,http://localhost:8000,http://localhost:7860

# Gradio Frontend Settings
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=7860

# Database Configuration (MySQL 8.4 LTS)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=forex_user
MYSQL_PASSWORD=forex_password
MYSQL_DATABASE=forex_assistant
MYSQL_ROOT_PASSWORD=forex_root_password

# Redis Configuration (Caching & Rate Limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration (Celery Broker)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Vector Database Configuration (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Market Data API Configuration (e.g. Twelve Data / OANDA)
# Configure keys for your preferred market data provider
MARKET_DATA_API_KEY=your_market_data_api_key_here
MARKET_DATA_PROVIDER=mock # mock | twelvedata | oanda

# LLM Provider Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Optional: alternative providers supported by Pydantic AI
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=gpt-4o-mini # Default cost-effective model
AGENT_COORDINATOR_MODEL=gpt-4o # Model for complex orchestration
